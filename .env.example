# Copy this to .env and fill in values

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hackaton_db

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_with_secrets_token_hex_32

# JWT algorithm
ALGORITHM=HS256

# Token expiry in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
